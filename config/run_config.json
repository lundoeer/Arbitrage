{
  "api": {
    "base_url": "https://api.elections.kalshi.com/trade-api/v2"
  },
  "health": {
    "transport_heartbeat_stale_seconds": 1.5,
    "market_data_stale_seconds": 1.5,
    "max_lag_ms": 2000,
    "require_source_timestamp": true,
    "max_source_age_ms": 2500
  },
  "markets": {
    "target_series": "KXBTC15M",
    "target_market": ""
  },
  "buy": {
    "min_gross_edge_threshold": 0.04,
    "max_spend_per_market_usd": 12.0,
    "max_size_cap_per_leg": 10.0,
    "min_size_per_leg_contracts": 5.0,
    "min_notional_per_leg_usd": 0.0,
    "best_ask_size_safety_factor": 0.5,
    "market_emulation_slippage": 0.1
  },
  "sell": {
    "min_gross_edge_threshold": 0.02,
    "max_size_cap_per_leg": 10.0,
    "min_size_per_leg_contracts": 5.0,
    "min_notional_per_leg_usd": 0.0,
    "best_bid_size_safety_factor": 0.5,
    "market_emulation_slippage": 0.1
  },
  "buy_execution": {
    "enabled": true,
    "cooldown_ms": 17000,
    "max_attempts_per_run": 3,
    "parallel_leg_timeout_ms": 10000,
    "api_retry": {
      "enabled": true,
      "max_attempts": 3,
      "base_backoff_seconds": 0.5,
      "jitter_ratio": 0.2,
      "include_post": true
    }
  },
  "sell_execution": {
    "enabled": false,
    "parallel_leg_timeout_ms": 10000,
    "api_retry": {
      "enabled": true,
      "max_attempts": 3,
      "base_backoff_seconds": 0.5,
      "jitter_ratio": 0.2,
      "include_post": true
    }
  },
  "position_monitoring": {
    "enabled": true,
    "require_bootstrap_before_buy": true,
    "polymarket_user_ws_enabled": true,
    "kalshi_market_positions_ws_enabled": true,
    "kalshi_user_orders_ws_enabled": true,
    "polymarket_poll_seconds": 15.0,
    "kalshi_poll_seconds": 15.0,
    "polymarket_orders_poll_seconds": 30.0,
    "kalshi_orders_poll_seconds": 30.0,
    "loop_sleep_seconds": 0.2,
    "drift_tolerance_contracts": 0.0,
    "max_exposure_per_market_usd": 22.0,
    "include_pending_orders_in_exposure": true,
    "stale_warning_seconds": 45,
    "stale_error_seconds": 60
  },
  "reverse_strategy": {
    "enabled": true,
    "poll_interval_seconds": 10.0,
    "loop_sleep_seconds": 1.0,
    "observation_window_seconds": 120,
    "yes_threshold": 0.97,
    "no_threshold": 0.03,
    "order_limit_price": 0.49,
    "order_size": 10,
    "dry_run": false,
    "output_dir": "data/limit_market",
    "state_file": "data/limit_market/reverse_strategy_state.json",
    "start_price_capture_grace_seconds": 20,
    "resolution_wait_after_end_seconds": 45,
    "rtds_symbol": "BTC/USD",
    "rtds_max_age_ms": 15000,
    "rtds_resolution_epsilon_usd": 0.0,
    "preclose_last_trade_seconds_before_end": 1,
    "preclose_yes_upper_threshold": 0.70,
    "preclose_yes_lower_threshold": 0.30,
    "ws_resolution_fallback_after_close_seconds": 600,
    "previous_window_resolution_grace_seconds": 120,
    "log_events": true,
    "log_decision_polls": true,
    "log_order_attempts": true,
    "future_markets_log_enabled": true,
    "future_markets_log_interval_seconds": 10.0,
    "future_markets_log_filename_template": "future_markets__{run_id}.jsonl"
  },
  "execution": {
    "best_ask_and_bids_at_max": 0.89,
    "best_ask_and_bids_at_min": 0.11,
    "market_start_trade_time_seconds": 0,
    "market_end_trade_time_seconds": 0
  }
}
