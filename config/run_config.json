{
  "api": {
    "base_url": "https://api.elections.kalshi.com/trade-api/v2"
  },
  "health": {
    "transport_heartbeat_stale_seconds": 1.5,
    "market_data_stale_seconds": 1.5,
    "max_lag_ms": 2000,
    "require_source_timestamp": true,
    "max_source_age_ms": 2500
  },
  "markets": {
    "target_series": "KXBTC15M",
    "target_market": ""
  },
