    "kalshi_poll_seconds": 20.0,
    "loop_sleep_seconds": 0.2,
    "drift_tolerance_contracts": 0.0,
    "stale_warning_seconds": 60,
    "stale_error_seconds": 180
  },
  "execution": {
    "best_ask_and_bids_at_max": 0.88,
    "best_ask_and_bids_at_min": 0.12,
